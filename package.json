{
  "name": "ctms-core",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "db:up": "docker compose up -d --wait",
    "db:migrate": "pnpm --filter @ctms/db migrate",
    "db:seed": "pnpm --filter @ctms/db seed",
    "db:reset": "docker compose down -v && docker compose up -d --wait && pnpm db:migrate && pnpm db:seed",
    "dev": "pnpm --parallel --filter @ctms/api --filter @ctms/web dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
