# Substituted by the nginx image entrypoint at startup: ${API_PROXY_TARGET}
# comes from the environment; nginx runtime variables ($host, $uri, ...) are
# untouched because they are not defined environment variables.
server {
    listen 5173;

    root /usr/share/nginx/html;
    index index.html;

    gzip on;
    gzip_types text/css application/javascript application/json image/svg+xml;

    # The SPA always calls /api/*; the trailing slash on proxy_pass strips
    # the /api prefix, matching the Vite dev proxy this replaces.
    location /api/ {
        proxy_pass ${API_PROXY_TARGET}/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Document uploads stream through here; cap matches practical TMF
        # artifact sizes, not nginx's 1m default.
        client_max_body_size 100m;
    }

    # Runtime SPA auth config from container env: one pinned image serves
    # any IdP. Exact-match wins over the static dev stub in the bundle.
    location = /env.js {
        default_type application/javascript;
        add_header Cache-Control "no-cache";
        return 200 'window.__CTMS_ENV__={AUTH_MODE:"${CTMS_WEB_AUTH_MODE}",OIDC_ISSUER:"${CTMS_WEB_OIDC_ISSUER}",OIDC_CLIENT_ID:"${CTMS_WEB_OIDC_CLIENT_ID}",OIDC_SCOPE:"${CTMS_WEB_OIDC_SCOPE}"};';
    }

    # Hashed bundle files never change content under the same name.
    location /assets/ {
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # index.html references the current hashes; always revalidate it.
    location = /index.html {
        add_header Cache-Control "no-cache";
    }

    # Client-side routes (/studies/..., /queue/...) resolve to the SPA shell.
    location / {
        try_files $uri /index.html;
    }
}
