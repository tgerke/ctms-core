{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@ctms/api", "dev"],
      "port": 8787
    },
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@ctms/web", "dev"],
      "port": 5173
    },
    {
      "name": "web-5199",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@ctms/web", "dev", "--port", "5199", "--strictPort"],
      "port": 5199
    },
    {
      "name": "docs-site",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-c", "pnpm --filter site dev --port ${PORT:-4321}"],
      "port": 4321,
      "autoPort": true
    }
  ]
}
