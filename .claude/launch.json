{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@ctms/api", "dev"],
      "port": 8787
    },
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@ctms/web", "dev"],
      "port": 5173
    },
    {
      "name": "docs-site",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-c", "cd docs-site/_site && python3 -m http.server 8123"],
      "port": 8123
    }
  ]
}
