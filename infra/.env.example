# Production environment for infra/compose.prod.yaml. Copy to .env next to
# the compose file, fill in the required values, then:
#
#   docker compose -f compose.prod.yaml up -d
#
# This is the production flavor; the repo-root .env.example is the dev one.
# Work through docs/05-deployment.md (IdP registration, Object Lock, backups,
# role rotation) before real documents touch the system. Lines left commented
# out are simply absent from the api container.
#
# NEVER run `pnpm db:seed` against this stack: the seed truncates every table.

# ---- Required ---------------------------------------------------------------

# Hostname the stack is served on. Must resolve to this host for Caddy to
# obtain a certificate; use "localhost" only for a local smoke test.
CTMS_DOMAIN=ctms.example.org

# Released version to run (image tag, without the leading v). Pin an exact
# release. Never "latest".
CTMS_VERSION=0.1.0

# Owning-role password for the bundled PostgreSQL (local-db profile) and
# runtime-role password for ctms_app. Generate each:
#   openssl rand -base64 24
# The migrate one-shot rotates ctms_app to this value on every bring-up.
POSTGRES_PASSWORD=
CTMS_APP_PASSWORD=

# Authentication mode. dev is a demo affordance (static bearer tokens,
# no real identity) — anything real runs oidc. The api refuses to boot
# without an explicit choice.
AUTH_MODE=oidc

# Which optional services run. local-db = the bundled PostgreSQL (drop it
# when DATABASE_URL points at a managed Postgres); add s3-local for the
# bundled MinIO if you must self-host object storage.
COMPOSE_PROFILES=local-db

# ---- OIDC (required when AUTH_MODE=oidc) ------------------------------------

# Any OIDC-compliant IdP: Okta, Entra ID, Auth0, Keycloak, ...
OIDC_ISSUER=https://idp.example.org/realms/main
OIDC_AUDIENCE=ctms-api
# Public (PKCE) client the web SPA logs in with; registered separately from
# the api audience (docs/05-deployment.md "Identity provider").
OIDC_WEB_CLIENT_ID=ctms-web
#OIDC_JWKS_URI=            # optional; defaults to the issuer's discovery document
#OIDC_EMAIL_CLAIM=email    # claim that maps the token to a person record
# Machine identities (client-credentials tokens carry no email claim):
# map token subjects to provisioned person records, comma-separated.
# This is how an EDC files documents into the TMF (ADR-0011).
#API_SERVICE_SUBJECTS=edc-filing-client:edc.filing@example.org
#REAUTH_MAX_AGE_SECONDS=300  # §11.200 signing re-auth freshness window

# ---- Optional passwords and roles -------------------------------------------

# Analyst SQL account (docs/04-api.md); rotated alongside ctms_app when set.
#CTMS_READONLY_PASSWORD=

# ---- Managed database (instead of the local-db profile) ---------------------

# Owning role for migrations, runtime role for the api. When the connection
# crosses a host boundary, require TLS. Remove local-db from COMPOSE_PROFILES.
#DATABASE_URL=postgres://ctms:...@db.internal:5432/ctms?sslmode=verify-full
#DATABASE_URL_APP=postgres://ctms_app:...@db.internal:5432/ctms?sslmode=verify-full

# ---- Object storage ----------------------------------------------------------

# Without this block documents land on the local storage volume
# (content-addressed, but no WORM guarantee). The pilot posture is a real
# S3 bucket created WITH Object Lock and a COMPLIANCE retention rule.
#STORAGE_DRIVER=s3
#S3_ENDPOINT=                        # omit for AWS; MinIO: http://minio:9000
#S3_REGION=us-east-1
#S3_BUCKET=ctms-documents
#S3_ACCESS_KEY_ID=
#S3_SECRET_ACCESS_KEY=
#S3_FORCE_PATH_STYLE=true            # required for MinIO
#S3_OBJECT_LOCK_MODE=COMPLIANCE      # omit to use the bucket's default rule
#S3_OBJECT_LOCK_RETENTION_DAYS=3650

# Bundled MinIO (s3-local profile) root credentials, if you use it.
#MINIO_ROOT_USER=ctms
#MINIO_ROOT_PASSWORD=

# ---- Oversight digest (ADR-0017) ---------------------------------------------

# Stateless; schedule from the host, e.g. weekdays at 07:00:
#   0 7 * * 1-5 cd /opt/ctms && docker compose -f compose.prod.yaml run --rm api pnpm digest
#SMTP_URL=smtp://relay.example.org:587
#DIGEST_FROM=ctms-core digest <digest@example.org>
#DIGEST_TO=                 # optional: override the derived recipient list
