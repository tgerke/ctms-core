# Postgres from docker-compose.yml — owning role, used by migrations and seed.
DATABASE_URL=postgres://ctms:ctms@localhost:5433/ctms
# The API itself always connects as the least-privilege ctms_app role
# (derived from DATABASE_URL; override with DATABASE_URL_APP or
# CTMS_APP_PASSWORD after rotating the role password in production).
# apps/api
API_PORT=8787

# Blob storage: 'local' (dev directory, default) or 's3' (any S3-compatible
# store; with Object Lock on the bucket, document bytes become WORM).
STORAGE_DRIVER=local
# S3_ENDPOINT=http://localhost:9000   # MinIO from docker-compose
# S3_REGION=us-east-1
# S3_BUCKET=ctms-documents
# S3_ACCESS_KEY_ID=ctms
# S3_SECRET_ACCESS_KEY=ctms-minio
# S3_FORCE_PATH_STYLE=true            # required for MinIO
# S3_OBJECT_LOCK_MODE=COMPLIANCE      # omit to use the bucket's default rule
# S3_OBJECT_LOCK_RETENTION_DAYS=3650

# Authentication mode: 'dev' (static tokens below, demo only) or 'oidc'.
# The API refuses to start without an explicit mode.
AUTH_MODE=dev
# dev-only bearer tokens, see docs/04-api.md
API_TOKEN_ADMIN=dev-admin-token
API_TOKEN_MONITOR=dev-monitor-token
# machine identity for source-system filing (EDC -> TMF, ADR-0011)
API_TOKEN_SERVICE=dev-service-token

# AUTH_MODE=oidc — validate bearer JWTs from a real identity provider.
# Works with any OIDC-compliant IdP (Okta, Entra ID, Auth0, Keycloak, ...).
# OIDC_ISSUER=https://idp.example.com/realms/ctms
# OIDC_AUDIENCE=ctms-api
# OIDC_JWKS_URI=            # optional; defaults to the issuer's discovery document
# OIDC_EMAIL_CLAIM=email    # claim that maps the token to a person record
# Machine identities (client-credentials tokens carry no email claim):
# map token subjects to provisioned person records, comma-separated.
# API_SERVICE_SUBJECTS=edc-filing-client:edc.filing@corc.example
# REAUTH_MAX_AGE_SECONDS=300  # §11.200 signing re-auth freshness window
